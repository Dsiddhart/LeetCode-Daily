class Solution {
public:
    int maximumElementAfterDecrementingAndRearranging(vector<int>& arr) {
        sort(arr.begin(),arr.end());
        if(arr[0]!=1){
            arr[0]=1;
        }
        int maxi=arr[0];
        int n = arr.size();
        for(int i=0;i<n-1;i++){
            if((arr[i+1]-arr[i])<=1){// check the first operation rule
                maxi=max(maxi,arr[i+1]);
            }    
            else{
                arr[i+1]=arr[i]+1;
                maxi=max(arr[i+1],maxi);
            }
        }
        return maxi;
    }
};
